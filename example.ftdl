import core,
particle u = {u, u~} @fermi,
particle d = {d, d~} @fermi,
particle g = {g} @boson,
particle h = {h} @boson,
particle b = {b, b~} @fermi,
particle e = {e+, e-} @fermi,
particle z = {z} @boson,
vertex hbb [h, b, b~] @core,
vertex gqq [g, q, q~] @core,
vertex zll [z, l+, l-] @core,
vertex qqg [q, q~, g] @core,
h(1) > b(2) b~(3),
e+(1) e-(2) > z(3),
g(1) g(2) > q(3) q~(4)
